<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.usb.host" android:required="true" />
    <!-- For fetching a linked repo's GitHub releases and downloading firmware assets. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.EspOtg"
        android:supportsRtl="true">

        <!--
          No USB_DEVICE_ATTACHED intent-filter here on purpose. Declaring it on
          the launcher activity makes the system repeatedly pull the app back to
          the foreground while a matching device stays plugged in (very visible on
          Samsung/One UI): you can't switch to another app without it stealing
          focus. We don't need it - the app enumerates devices at runtime
          (UsbSerialProber in UsbDeviceRepository) and requests permission itself.
          The only thing lost is "open with EspOtg" on plug-in; if we want that
          back later, it must go on a dedicated trampoline activity (noHistory /
          excludeFromRecents), never on this one. res/xml/device_filter.xml is
          kept for that future use.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
